CTRADER_PORT=5035

# --- Interactive Brokers (TWS / Gateway) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# --- Gestion du risque ---
MAX_RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=5
