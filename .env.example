# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Broker actif : ctrader | ibkr | paper
BROKER=paper

# Secret partagé pour authentifier les webhooks de signaux entrants
